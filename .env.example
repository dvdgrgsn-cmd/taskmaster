# ─────────────────────────────────────────────────────────────────────────────
# TASKMASTER — local configuration
# Copy this file to .env and fill in your values.
# The .env file is NEVER committed — it stays on your machine only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude (Anthropic) ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: override the default model
CLAUDE_MODEL=claude-opus-4-5

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Optional: override the default model (gpt-4o, gpt-4-turbo, etc.)
OPENAI_MODEL=gpt-4o

# ── Email / SMTP (Gmail) ──────────────────────────────────────────────────────
# For server-side email sending (optional — app also works with mailto: links).
# Use your Gmail address + an App Password (NOT your regular Gmail password).
# Create an App Password at: https://myaccount.google.com/apppasswords
# You need 2FA enabled on your Google account first.
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password

# ── Auto Daily Email Scheduler (for Vercel cron) ─────────────────────────────
# Cron endpoint security secret (set same value in Vercel env vars)
CRON_SECRET=replace_with_long_random_string

# Vercel Hobby runs this at 06:00 UTC daily via vercel.json cron.
# If you need a different timezone's 6:00am, adjust the cron schedule manually.

# ── Vercel KV (required for reliable scheduled sends) ─────────────────────────
# Add these in Vercel project env vars after connecting Vercel KV
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Optional Postgres DB (preferred for durable cross-device tasks) ───────────
# Use a Vercel Postgres or Neon connection string.
POSTGRES_URL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002
